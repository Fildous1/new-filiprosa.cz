# ============================================================
# API Routing & CORS — cdn.filiprosa.cz/api/
# ============================================================

<IfModule mod_headers.c>
    SetEnvIf Origin "http(s)?://(localhost:3000|new\.filiprosa\.cz|filiprosa\.cz)$" AccessControlAllowOrigin=$0
    Header always set Access-Control-Allow-Origin %{AccessControlAllowOrigin}e env=AccessControlAllowOrigin

    Header always set Access-Control-Allow-Methods "POST, GET, OPTIONS, DELETE, PUT"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-Api-Key"
    Header always set Access-Control-Allow-Credentials "true"
</IfModule>

RewriteEngine On

# Handle OPTIONS preflight before any rewriting
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Clean URLs — /api/upload → upload.php etc.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L,QSA]

<FilesMatch "\.php$">
    Require all granted
</FilesMatch>

# Block direct access to config
<Files "config.php">
    Require all denied
</Files>

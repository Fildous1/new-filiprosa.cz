# ============================================================
# API Routing & CORS Fix — cdn.filiprosa.cz/api/
# ============================================================

<IfModule mod_headers.c>
    # Povolíme tvůj nový web i localhost pro vývoj
    SetEnvIf Origin "http(s)?://(localhost:3000|new\.filiprosa\.cz|filiprosa\.cz)$" AccessControlAllowOrigin=$0
    Header always set Access-Control-Allow-Origin %{AccessControlAllowOrigin}e env=AccessControlAllowOrigin
    
    Header always set Access-Control-Allow-Methods "POST, GET, OPTIONS, DELETE, PUT"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
    Header always set Access-Control-Allow-Credentials "true"
</IfModule>

RewriteEngine On

# 1. Zachytíme OPTIONS (Preflight) dřív, než se to přepíše na PHP
# Server odpoví 200 OK a nepokračuje dál
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# 2. Clean URLs — /api/contact -> contact.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L,QSA]

# 3. Zabezpečení PHP (Apache 2.4)
<FilesMatch "\.php$">
    Require all granted
</FilesMatch>

<Files "config.php">
    Require all denied
</Files>